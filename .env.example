# Africa's Talking SMS credentials
# Copy this file to .env and fill in your real values

# Get these from: https://account.africastalking.com/
AT_API_KEY=your_api_key_here
AT_USERNAME=your_username_here

# Optional: your registered sender ID (e.g. "CHEWAZ")
# Leave blank to use the shared shortcode
AT_SENDER=

